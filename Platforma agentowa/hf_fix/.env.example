# Copy to .env and adjust. docker-compose automatically reads .env.

# --- PostgreSQL (dev defaults) ---
# These are also used to build DATABASE_URL for api-server, so credentials
# are declared only once. Override POSTGRES_PASSWORD for any shared/prod env.
POSTGRES_USER=hyperflow
POSTGRES_PASSWORD=hyperflow
POSTGRES_DB=hyperflow

# --- Hyperflow Core (Python) ---
# Leave empty to use deterministic stub mode (no external LLM calls).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- API Server (Node.js) ---
# Bearer token used when HARDENED_MODE=true. Leave empty in dev.
API_TOKEN=
LOG_LEVEL=info
# Hardened mode defaults to on.  Set HARDENED_MODE=false only during local development.
HARDENED_MODE=true
# Internal token that the api-server must forward to the Python core.  Set a strong secret in production.
HYPERFLOW_CORE_TOKEN=
# Environment passed to the Python core to trigger production mode (token required).
HYPERFLOW_ENV=production
# Express trust proxy setting.  Leave 0 when not behind a reverse proxy; set to 1 behind one.
TRUST_PROXY=0
