{
  "name": "@workspace/scripts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "hello": "tsx ./src/hello.ts",
    "db:backup": "tsx ./src/db-backup.ts",
    "db:restore": "tsx ./src/db-restore.ts",
    "db:cleanup": "tsx ./src/db-cleanup.ts",
    "db:migrate:generate": "pnpm --filter @workspace/db exec drizzle-kit generate --config ./drizzle.config.ts",
    "db:migrate:push": "pnpm --filter @workspace/db run push",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "tsx": "catalog:"
  }
}
